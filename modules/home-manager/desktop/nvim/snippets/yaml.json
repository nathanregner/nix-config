{
  "logging_level": {
    "prefix": "logging_level",
    "body": ["- name: LOGGING_LEVEL_WEB", "  value: DEBUG"]
  },
  "actuator-exposure": {
    "prefix": "actuator-exposure",
    "body": [
      "- name: MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE",
      "  value: health,prometheus,loggers,metrics,threaddump"
    ]
  },
  "logging-level-rest-client": {
    "prefix": "logging-level-rest-client",
    "body": [
      "- name: LOGGING_LEVEL_ORG_APACHE_HC_CLIENT5_HTTP_WIRE",
      "  value: DEBUG"
    ]
  },
  "spring-profile-groups": {
    "prefix": "spring-profile-groups",
    "body": [
      "group:",
      "  local: clickbank",
      "  dev: clickbank",
      "  staging: clickbank",
      "  prod: clickbank",
      "  sphere-local: sphere",
      "  sphere-dev: sphere",
      "  sphere-staging: sphere",
      "  sphere-prod: sphere"
    ]
  },
  "ecr-image-nregner": {
    "prefix": "ecr-image-nregner",
    "body": "image: 557126177626.dkr.ecr.us-west-2.amazonaws.com/nregner"
